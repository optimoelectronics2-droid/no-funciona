rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function roleIn(roles) { return signedIn() && request.auth.token.role in roles; }

    match /accounts/{userId}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /invoices/{id} {
      allow read: if signedIn();
      allow create: if roleIn(['Admin', 'Supervisor', 'Cajero', 'Vendedor']);
      allow update: if roleIn(['Admin', 'Supervisor', 'Contador'])
        && (!('status' in resource.data) || request.resource.data.status == 'voided')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'voidReason', 'voidedAt', 'updatedAt']);
      allow delete: if false;
    }

    match /tax_sequences/{id} {
      allow read: if signedIn();
      allow write: if roleIn(['Admin', 'Contador']);
    }

    match /products/{id} {
      allow read: if signedIn();
      allow write: if roleIn(['Admin', 'Supervisor', 'Bodeguero']);
    }

    match /audit_logs/{id} {
      allow read: if roleIn(['Admin', 'Supervisor', 'Contador']);
      allow create: if signedIn();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read: if signedIn();
      allow write: if roleIn(['Admin', 'Supervisor']);
    }
  }
}
